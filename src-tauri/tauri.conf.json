{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "treed-shell",
  "version": "0.1.0",
  "identifier": "com.treed.shell",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "tsc -b && vite build"
  },
  "app": {
    "windows": [
      {
        "title": "TreeD Shell",
        "width": 1200,
        "height": 760,
        "minWidth": 1000,
        "minHeight": 620,
        "center": true,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#2B2F36"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
