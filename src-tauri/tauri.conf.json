{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "treed-shell",
  "version": "0.1.0",
  "identifier": "com.treed.shell",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TreeD Shell",
        "width": 960,
        "height": 544,
        "minWidth": 960,
        "minHeight": 544,
        "resizable": false,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
