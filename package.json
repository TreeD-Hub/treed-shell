{
  "name": "treed-shell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/printer-logic",
    "apps/web-ui"
  ],
  "scripts": {
    "dev:mock": "npm run build:logic && vite --mode mock",
    "dev:live": "npm run build:logic && vite --mode live",
    "dev:web-ui": "npm run build:logic && npm run dev --workspace treed-web-ui",
    "build": "npm run build:logic && npm run build:ui:shell && npm run build:web-ui",
    "build:logic": "npm run build --workspace @treed/printer-logic",
    "build:web-ui": "npm run build --workspace treed-web-ui",
    "build:ui:shell": "tsc -b && vite build --mode live",
    "build:ui:printer": "npm run build:logic && npm run build:ui:shell",
    "tauri:dev": "tauri dev",
    "tauri:dev:printer": "tauri dev --config src-tauri/tauri.printer.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:printer": "tauri build --config src-tauri/tauri.printer.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@treed/printer-logic": "file:packages/printer-logic",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
